    "slug": "smart-agriculture-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1B0E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartagriculture.ai"
    },
